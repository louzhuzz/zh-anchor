{
  "$schema": "https://raw.githubusercontent.com/cortexkit/opencode-magic-context/main/schema.json",
  "historian": {
    "frequency": "never",
    "provider": {
      "deepseek": {
        "model": "deepseek-v4-flash"
      }
    }
  },
  "dreamer": {
    "frequency": "never",
    "provider": {
      "deepseek": {
        "model": "deepseek-v4-flash"
      }
    }
  },
  "cache": {
    "ttl": "30s",
    "executeThreshold": 80
  },
  "nudges": {
    "enabled": false
  }
}
